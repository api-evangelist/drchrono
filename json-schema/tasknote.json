{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api-evangelist.github.io/drchrono/json-schema/tasknote.json",
  "title": "TaskNote",
  "required": [
    "task",
    "text"
  ],
  "type": "object",
  "properties": {
    "archived": {
      "type": "boolean",
      "description": "If the task note is archived or not",
      "title": "Archived"
    },
    "task": {
      "type": "integer",
      "description": "ID of task this note is related with",
      "title": "Task"
    },
    "text": {
      "type": "string",
      "description": "Content of the task note",
      "title": "Text"
    },
    "created_at": {
      "readOnly": true,
      "type": "string",
      "description": "",
      "title": "Created at"
    },
    "updated_at": {
      "readOnly": true,
      "type": "string",
      "description": "",
      "title": "Updated at"
    },
    "created_by": {
      "readOnly": true,
      "type": "string",
      "description": "ID of the `/api/users` who created the note",
      "title": "Created by"
    },
    "id": {
      "readOnly": true,
      "type": "integer",
      "description": "",
      "title": "ID"
    }
  },
  "x-verbose-required": []
}